# MariaDB connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=mooindagcounter
DB_PASSWORD=example
DB_NAME=mooindagcounter

# TLS voor remote databases (managed database of aparte database-app).
# DB_SSL=true zodra de database NIET op localhost draait.
# DB_SSL_VERIFY=false bij self-signed certificaten (standaard bij MariaDB).
# DB_SSL_CA: pad naar CA-bundel, vereist door sommige managed diensten.
DB_SSL=false
DB_SSL_VERIFY=true
DB_SSL_CA=

# Verbindingsgedrag (optioneel)
DB_CONNECT_TIMEOUT=10
DB_POOL_RECYCLE=280

# Discord webhook (optional)
DISCORD_WEBHOOK_URL=

# Gunicorn workers (optional, defaults to 2)
GUNICORN_WORKERS=2
