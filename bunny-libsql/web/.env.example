# Bunny Database (libSQL) verbinding
# Productie: URL + access token uit het Bunny dashboard (Database > Connect):
#   LIBSQL_URL=libsql://<database-id>.lite.bunnydb.net
#   LIBSQL_AUTH_TOKEN=<token>
# Lokaal (docker compose met sqld): http://db:8080 met leeg token.
LIBSQL_URL=http://db:8080
LIBSQL_AUTH_TOKEN=

# Discord webhook (optional)
DISCORD_WEBHOOK_URL=

# Gunicorn workers (optional, defaults to 2)
GUNICORN_WORKERS=2

# Wachtwoord voor de verwijder-knop (verplicht om te kunnen verwijderen).
# Alleen als secret instellen, nooit committen.
DELETE_PASSWORD=
