<body>
    <div class="container">
        <h1>Mooindag counter</h1> <!-- Toegevoegde titel -->
        <h2>{{ counter }}</h2>
        <form action="/increment" method="post">
            <button type="submit">Increment</button>
        </form>

        <form action="/decrement" method="post">
            <button type="submit">Decrement</button>
        </form>


        <div class="footer">Moest van Sten Tijhuis</div> <!-- Voettekst -->
    </div>
