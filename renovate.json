{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "forkProcessing": "enabled",
  "pinDigests": true,
  "enabledManagers": [
    "pip_requirements",
    "dockerfile",
    "docker-compose",
    "github-actions"
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true
    }
  ]
}
